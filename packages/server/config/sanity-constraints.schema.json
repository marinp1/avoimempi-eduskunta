{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avoimempi-eduskunta.local/sanity-constraints.schema.json",
  "title": "Sanity Constraints",
  "description": "Human-maintained source of truth for sanity checks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "constraints"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/constraint"
      }
    }
  },
  "$defs": {
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Stable machine-readable identifier."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Must match emitted sanity check name."
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "query_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tableNames",
              "personIdDuplicates",
              "representativeNullPersonId",
              "representativeMissingNames",
              "sessionEmptyKeys",
              "sessionEmptyDates",
              "sessionTotalCount",
              "sessionUniqueKeyCount",
              "sectionSessionOrphans",
              "parliamentOversizedDates",
              "votingTotalOver200",
              "votingSumMismatch",
              "votingIndividualCountMismatch",
              "votingDuplicateNumbers",
              "votingSessionOrphans",
              "voteInvalidValues",
              "voteDuplicateByPerson",
              "representativeInvalidGender",
              "representativeWithoutTerms",
              "termInvalidDates",
              "groupMembershipInvalidDates",
              "speechSessionOrphans",
              "speechContentSpeechOrphans",
              "speechMetadataWithoutContent",
              "speechMetadataWithoutContentUnexpected",
              "speechHasSpokenZeroWithContent",
              "speechContentCount",
              "speechContentNameComparedCount",
              "speechContentNameMismatches",
              "voteRepresentativeOrphans",
              "schemaIndexes",
              "voteAggregationMismatch",
              "votingSessionDateMismatch",
              "votingSectionOrphans",
              "committeeMembershipInvalidDates",
              "governmentMembershipInvalidDates",
              "governmentMembershipEmptyGovernment",
              "districtCount",
              "representativeDistrictOverlaps",
              "sessionTooOld",
              "sessionInFuture",
              "activeMpWithoutGroup",
              "activeGroupMemberMismatch"
            ]
          }
        },
        "query_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "params": {
          "type": "object",
          "description": "Constraint-specific configurable values consumed by check logic.",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
