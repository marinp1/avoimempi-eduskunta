# Storage Configuration
# Choose storage provider: local, s3, r2, minio
STORAGE_PROVIDER=local

# Local Storage (default)
STORAGE_LOCAL_DIR=./data

# S3-Compatible Storage (AWS S3, Cloudflare R2, MinIO, etc.)
# Uncomment and configure when using cloud storage
# STORAGE_PROVIDER=s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=eduskunta-data
# STORAGE_S3_ACCESS_KEY_ID=your-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key
# STORAGE_S3_ENDPOINT=https://your-endpoint (for R2/MinIO only)

# Example for Cloudflare R2:
# STORAGE_PROVIDER=r2
# STORAGE_S3_REGION=auto
# STORAGE_S3_BUCKET=eduskunta-data
# STORAGE_S3_ACCESS_KEY_ID=your-r2-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-r2-secret-key
# STORAGE_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
