# Storage Configuration
# Choose storage provider: local (only supported option)
STORAGE_PROVIDER=local

# Local Storage (default)
STORAGE_LOCAL_DIR=./data

# Row Store Configuration
# sqlite (default): stores raw/parsed rows in local SQLite files (raw.db, parsed.db)
# postgres: use Scaleway Serverless SQL Database or any Postgres-compatible server
# ROW_STORE_PROVIDER=postgres
# ROW_STORE_DATABASE_URL=postgres://user:pass@host:5432/dbname

# Override row-store directory (default: same as STORAGE_LOCAL_DIR)
# ROW_STORE_DIR=./data

# Database Paths
# DB_PATH=../../../avoimempi-eduskunta.db
# TRACE_DB_PATH=../../../avoimempi-eduskunta-trace.db

# Server Database Launch Mode
# local (default): use local DB file at DB_PATH (or default path)
# latest: fetch DB key from artifacts/sqlite/latest/manifest.json in storage
# storage-key: fetch DB directly from SERVER_DB_LAUNCH_STORAGE_KEY in storage
# SERVER_DB_LAUNCH_MODE=local
# SERVER_DB_LAUNCH_MODE=latest
# SERVER_DB_LAUNCH_MODE=storage-key
# SERVER_DB_LAUNCH_STORAGE_KEY=artifacts/sqlite/snapshots/2026-02-18T12-00-00-000Z/avoimempi-eduskunta.db
# SERVER_TRACE_DB_LAUNCH_STORAGE_KEY=artifacts/sqlite/snapshots/2026-02-18T12-00-00-000Z/avoimempi-eduskunta-trace.db

# Optional: acquire EXCLUSIVE SQLite lock during migration for extra speed
# Use only in isolated worker environments where serving reads during migration is not needed.
# MIGRATOR_EXCLUSIVE_LOCK=true

# Optional: post-import VACUUM to compact SQLite file (default true)
# MIGRATOR_VACUUM_AFTER_IMPORT=true

# Optional: cap indexed search body size per federated-search row (default 4096)
# Set to full/off/none to disable truncation
# MIGRATOR_FEDERATED_SEARCH_BODY_MAX_CHARS=4096

# Optional: limit VaskiData migration to specific document types (comma-separated)
# By default all supported document types are migrated
# VASKI_DOCUMENT_TYPES=hallituksen_esitys,kansalaisaloite

# Optional: override directories for migration diagnostic log files
# MIGRATOR_REPORT_LOG_DIR=./data/migration-reports
# MIGRATOR_OVERWRITE_LOG_DIR=./data/migration-overwrites
# MIGRATOR_KNOWN_ISSUE_LOG_DIR=./data/migration-known-issues
