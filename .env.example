# Storage Configuration
# Choose storage provider: local, s3, r2, minio
STORAGE_PROVIDER=local

# Local Storage (default)
STORAGE_LOCAL_DIR=./data

# S3-Compatible Storage (AWS S3, Cloudflare R2, MinIO, etc.)
# Uncomment and configure when using cloud storage
# STORAGE_PROVIDER=s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=eduskunta-data
# STORAGE_S3_ACCESS_KEY_ID=your-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key
# STORAGE_S3_ENDPOINT=https://your-endpoint (for R2/MinIO only)

# Example for Cloudflare R2:
# STORAGE_PROVIDER=r2
# STORAGE_S3_REGION=auto
# STORAGE_S3_BUCKET=eduskunta-data
# STORAGE_S3_ACCESS_KEY_ID=your-r2-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-r2-secret-key
# STORAGE_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Example for Scaleway Object Storage:
# STORAGE_PROVIDER=s3
# STORAGE_S3_REGION=nl-ams
# STORAGE_S3_BUCKET=bkt-avoimempi-eduskunta-pipeline
# STORAGE_S3_ACCESS_KEY_ID=your-scaleway-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-scaleway-secret-key
# STORAGE_S3_ENDPOINT=https://s3.nl-ams.scw.cloud

# Server Database Launch Mode
# local (default): use local DB file at DB_PATH (or default path)
# latest: fetch DB key from artifacts/sqlite/latest/manifest.json in storage
# storage-key: fetch DB directly from SERVER_DB_LAUNCH_STORAGE_KEY in storage
# SERVER_DB_LAUNCH_MODE=local
# SERVER_DB_LAUNCH_MODE=latest
# SERVER_DB_LAUNCH_MODE=storage-key
# SERVER_DB_LAUNCH_STORAGE_KEY=artifacts/sqlite/snapshots/2026-02-18T12-00-00-000Z/avoimempi-eduskunta.db
# SERVER_TRACE_DB_LAUNCH_STORAGE_KEY=artifacts/sqlite/snapshots/2026-02-18T12-00-00-000Z/avoimempi-eduskunta-trace.db

# Optional: separate trace/lineage database path for source references
# TRACE_DB_PATH=../../../avoimempi-eduskunta-trace.db

# Optional: also publish per-run snapshot key during migration
# snapshots are written to artifacts/sqlite/snapshots/<run-id>/...
# MIGRATOR_PUBLISH_SNAPSHOT=true

# Optional: acquire EXCLUSIVE SQLite lock during migration for extra speed
# Use only in isolated worker environments where serving reads during migration is not needed.
# MIGRATOR_EXCLUSIVE_LOCK=true

# Optional: run non-blocking post-migration foreign-key check report
# Writes metadata/migration-runs/<run-id>/reports/foreign_key_check.json
# MIGRATOR_FOREIGN_KEY_CHECK=true
# MIGRATOR_FOREIGN_KEY_CHECK_SAMPLE_LIMIT=1000

# Optional: source reference persistence mode during migration
# full: store detailed ImportSourceReference rows + summary in TRACE_DB_PATH
# summary (default): store summary only in TRACE_DB_PATH
# off: skip source reference storage
# MIGRATOR_SOURCE_REFERENCE_MODE=summary

# Optional: post-import VACUUM to compact SQLite file (default true)
# MIGRATOR_VACUUM_AFTER_IMPORT=true

# Optional: cap indexed search body size per federated-search row (default 4096)
# Set to full/off/none to disable truncation
# MIGRATOR_FEDERATED_SEARCH_BODY_MAX_CHARS=4096

# Pipeline Queue Orchestration (SQS API; works with ElasticMQ locally)
# PIPELINE_SQS_ENDPOINT=http://localhost:9324
# PIPELINE_SQS_REGION=us-east-1
# PIPELINE_SQS_ACCESS_KEY_ID=x
# PIPELINE_SQS_SECRET_ACCESS_KEY=x
# PIPELINE_SQS_SESSION_TOKEN=
# Backward-compat alias (optional): PIPELINE_ELASTICMQ_ENDPOINT=http://localhost:9324
# PIPELINE_QUEUE_INSPECTOR=datapipe-inspector
# PIPELINE_QUEUE_SCRAPER=datapipe-scraper
# PIPELINE_QUEUE_PARSER=datapipe-parser
# PIPELINE_QUEUE_WAIT_SECONDS=10
# PIPELINE_QUEUE_MAX_MESSAGES=1
# Per-worker visibility timeouts (should match Terraform queue settings)
# PIPELINE_QUEUE_INSPECTOR_VISIBILITY_TIMEOUT_SECONDS=60
# PIPELINE_QUEUE_SCRAPER_VISIBILITY_TIMEOUT_SECONDS=600
# PIPELINE_QUEUE_PARSER_VISIBILITY_TIMEOUT_SECONDS=300
# PIPELINE_QUEUE_RETRY_VISIBILITY_TIMEOUT_SECONDS=15
# PIPELINE_QUEUE_IDLE_DELAY_MS=300
# PIPELINE_CHANGELOG_DB_PATH=./data/pipeline-orchestration.db
