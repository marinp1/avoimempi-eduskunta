# Sync local data/* folders to Scaleway Object Storage.
# Usage:
#   bun --env-file=.env.sync-storage-s3 run sync:storage:s3 --dry-run
#   bun --env-file=.env.sync-storage-s3 run sync:storage:s3

STORAGE_PROVIDER=s3
STORAGE_S3_BUCKET=bkt-avoimempi-eduskunta-pipeline
STORAGE_S3_ENDPOINT=https://s3.nl-ams.scw.cloud
STORAGE_S3_REGION=nl-ams

# Pick one credential style:
# 1) Storage-prefixed keys
# STORAGE_S3_ACCESS_KEY_ID=replace-with-scaleway-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=replace-with-scaleway-secret-key

# 2) Or AWS-compatible names (leave STORAGE_S3_* above empty/unused)
# 2) Or Scaleway names (leave STORAGE_S3_* above empty/unused)
# SCW_ACCESS_KEY=replace-with-scaleway-access-key
# SCW_SECRET_KEY=replace-with-scaleway-secret-key
# SCW_PROFILE=your-scaleway-profile

# Optional custom local source root (defaults to ./data)
# STORAGE_LOCAL_DIR=./data
