{
    "name": "Avoimempi Eduskunta Dev Container",
    "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
    "features": {},
    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "biomejs.biome"
            },
            "extensions": [
                "biomejs.biome",
                "anthropic.claude-code",
                "-GitHub.copilot-chat",
                "-GitHub.copilot"
            ]
        }
    },
    "forwardPorts": [
        3000
    ],
    "init": true,
    "remoteUser": "node",
    "postCreateCommand": "./install.sh",
    "runArgs": []
}
