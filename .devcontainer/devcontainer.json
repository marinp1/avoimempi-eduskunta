{
    "name": "Avoimempi Eduskunta Dev Container",
    "image": "docker.io/oven/bun:1.3.8-slim",
    "features": {
        "ghcr.io/devcontainers/features/git:1.3.5": {
            "ppa": false
        },
        "ghcr.io/devcontainers/features/common-utils:2.5.6": {
            "installZsh": true,
            "configureZshAsDefaultShell": true
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "biomejs.biome"
            },
            "extensions": [
                "biomejs.biome",
                "anthropic.claude-code",
                "-GitHub.copilot-chat",
                "-GitHub.copilot"
            ]
        }
    },
    "forwardPorts": [
        3000
    ],
    "init": true,
    "postCreateCommand": "./install.sh",
    "runArgs": [
        "--security-opt=label=disable",
        "--userns=keep-id"
    ],
    "containerEnv": {
        "DISPLAY": ""
    }
}
