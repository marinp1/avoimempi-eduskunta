{
    "name": "Avoimempi Eduskunta Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "workspace",
    "runServices": [
        "workspace",
        "elasticmq"
    ],
    "workspaceFolder": "/workspaces/avoimempi-eduskunta",
    "shutdownAction": "stopCompose",
    "features": {},
    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "biomejs.biome"
            },
            "extensions": [
                "biomejs.biome",
                "anthropic.claude-code",
                "-GitHub.copilot-chat",
                "-GitHub.copilot"
            ]
        }
    },
    "forwardPorts": [
        3000,
        9324
    ],
    "init": true,
    "remoteUser": "node",
    "updateRemoteUserUID": true,
    "postCreateCommand": "sudo chown -R node:node /workspaces/avoimempi-eduskunta /workspaces/avoimempi-eduskunta/node_modules && sh ./install.sh",
    "runArgs": []
}
