{
  "name": "eduskunta-forum",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "author": "",
  "license": "ISC",
  "description": "Data aggregation and analysis platform for Finnish Parliament",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.4",
    "@mui/material": "7.3.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "bun-sqlite-migrations": "1.0.2",
    "fast-xml-parser": "5.0.9",
    "i18next": "25.8.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "16.5.4",
    "recharts": "3.4.1",
    "xlsx": "0.18.5",
    "xml-js": "1.6.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@types/bun": "1.3.8",
    "@types/node": "22.13.4",
    "typescript": "5.7.3"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "NODE_ENV=development bun run packages/server/index.ts",
    "scrape": "cd packages/datapipe && bun run scraper/cli.ts",
    "parse": "cd packages/datapipe && bun run parser/cli.ts",
    "regen-source-status": "bun run scripts/regenerate-source-status.ts",
    "backfill:scraper-source-metadata": "bun run scripts/backfill-scraper-source-metadata.ts",
    "check:table-id-ranges": "bun run scripts/check-table-id-ranges.ts",
    "check:table-gaps-api": "bun run scripts/check-table-gaps-from-api.ts",
    "check:table-count-vs-api": "bun run scripts/validate-table-count-vs-api.ts",
    "check:vaski-id-ranges": "bun run scripts/check-table-id-ranges.ts VaskiData",
    "check:vaski-gaps-api": "bun run scripts/check-table-gaps-from-api.ts VaskiData",
    "migrate": "cd packages/datapipe && bun run migrator/cli.ts",
    "migrate:fresh": "cd packages/datapipe && bun run migrator/cli.ts recreate",
    "sync:storage:s3": "bun run scripts/sync-storage-to-s3.mts",
    "test": "bun test",
    "report:exception-candidates": "bun run packages/server/scripts/generate-known-exception-candidates.ts",
    "check:parliament-size-exact": "bun run packages/server/scripts/check-parliament-composition-exact-200.ts",
    "bench:sql": "bun run packages/server/scripts/benchmark-query-latency.ts",
    "bench:http": "bun run packages/server/scripts/benchmark-http-load.ts",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write"
  }
}
