    "@mui/icons-material": "7.3.4",
    "@mui/material": "7.3.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "bun-sqlite-migrations": "1.0.2",
    "fast-xml-parser": "5.0.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "3.4.1",
    "xlsx": "0.18.5",
    "xml-js": "1.6.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
